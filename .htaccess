# Anchored redirects for empty-dir / missing-target paths (regex-bounded so they
# don't capture sub-paths and avoid Apache prefix-suffix concatenation).
# (secure-elements is a live technology page — no redirect; it canonicalises to itself.)
RedirectMatch 301 ^/support/guides/use-fido-card/?$ /products/onepass-card/

# WordPress -> static cleanup: nuke any wp- crawl path with 410 (gone)
RedirectMatch 410 ^/wp-login\.php
RedirectMatch 410 ^/wp-admin(/.*)?$
RedirectMatch 410 ^/xmlrpc\.php$

# Custom 404
ErrorDocument 404 /404.html

# Cache headers (LiteSpeed honours these; Apache via mod_expires)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                 "access plus 7 days"
  ExpiresByType application/javascript   "access plus 7 days"
  ExpiresByType image/svg+xml            "access plus 30 days"
  ExpiresByType image/webp               "access plus 30 days"
  ExpiresByType image/png                "access plus 30 days"
  ExpiresByType image/jpeg               "access plus 30 days"
  ExpiresByType application/pdf          "access plus 30 days"
  ExpiresByType application/manifest+json "access plus 7 days"
  # Short HTML TTL during active iteration so re-deploys appear quickly;
  # bump back to "1 hour" (or longer) once the site stabilises.
  ExpiresByType text/html                "access plus 5 minutes"
</IfModule>

# Serve site.webmanifest with the correct MIME type per the PWA spec.
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  # X-Frame-Options is legacy/redundant with CSP frame-ancestors 'none' below,
  # but kept for older crawlers/browsers that ignore CSP framing rules.
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=(), browsing-topics=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # Block Flash/Silverlight cross-domain policy lookups (Adobe legacy).
  Header set X-Permitted-Cross-Domain-Policies "none"
  # CSP — Phase 20: tightened. Fonts are fully self-hosted; the previous
  # fonts.googleapis.com / fonts.gstatic.com allow-list was defensive but
  # unused. 'unsafe-inline' for style-src remains until the residual inline
  # `style=` attributes are class-extracted (tracked in OPEN_ITEMS).
  # GA4 origins added when provider flipped to "ga4" (Phase 37): gtag.js
  # loads from googletagmanager.com; collect beacons go to google-analytics.com
  # subdomains (regional endpoints use region1./region2./etc).
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://i.ytimg.com https://www.google-analytics.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; frame-src https://www.youtube-nocookie.com https://www.youtube.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto:; object-src 'none'; media-src 'self'; upgrade-insecure-requests"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/xml
</IfModule>
