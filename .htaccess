# =============================================================
# AmbiSecure — LiteSpeed / Apache rewrite + redirect rules
# =============================================================
# Hosting: Hostinger (LiteSpeed). LiteSpeed honours .htaccess.
# Strategy: 301 every legacy URL to its new home.
# Source-of-truth list lives in docs/01-audit-and-content-inventory.md
# and docs/04-seo-and-redirect-strategy.md.
# =============================================================

Options -MultiViews +FollowSymLinks
DirectoryIndex index.html

# Force HTTPS (Hostinger SSL is on; HSTS is set at the host level).
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Strip trailing index.html from URLs (canonicalise to directory form).
RewriteCond %{THE_REQUEST} \s/+(.*?)index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# =============================================================
# SEO-spam pattern killer — return 410 Gone (not 404) so Google
# de-indexes faster. These URL patterns are NOT site URLs; they
# are Japanese-keyword-hack / pharma-hack injection fingerprints
# that external spam networks have pointed at this domain. GSC
# reports ~250 such URLs as either 404 or "Crawled - currently
# not indexed". 410 is the correct signal: "permanently gone".
# Patterns confirmed against GSC Pages export (May 2026):
#   /<8-10 digits>.htm        (e.g. /100180190.htm)
#   /<5 letters>/<l><6-8 digits>.html  (e.g. /eusdh/c2784685.html)
# Both regexes are intentionally tight so no real URL matches.
# =============================================================
RewriteRule ^[0-9]{6,10}\.htm$ - [G,L]
RewriteRule ^[a-z]{5}/[a-z][0-9]{6,8}\.html$ - [G,L]

# =============================================================
# Phase 40 — Defensive hardening
# Static-site posture: NO server-side code is shipped. These rules
# are defence-in-depth so an accidental FTP upload of a .env/.git
# folder, a stray .php file from a future operator, or a probe for
# common CMS surfaces cannot be exploited or fingerprinted.
# Uses only portable mod_rewrite directives (LiteSpeed-safe; no
# <Files ~> regex blocks which LiteSpeed parses but with caveats).
# Order matters: these run BEFORE legacy 301 redirects so a probe
# for /wp-admin/install.php is blocked, not redirected.
# =============================================================

# Block all dotfile/dotdir access except /.well-known/ (ACME, security.txt).
RewriteCond %{REQUEST_URI} ^/\.(?!well-known/)
RewriteRule .* - [F,L]

# Block dangerous source/backup/config/key extensions at any depth.
RewriteRule \.(env|ini|log|sh|sql|bak|old|orig|save|swp|swo|dist|inc|tpl|tmpl|pem|key|crt|cert|p12|pfx|asc|gpg|sqlite|sqlite3|db)$ - [F,NC,L]

# Block source-control + dev artifacts (.git already covered above, but
# also block VCS-like names without leading dot, plus package manifests).
RewriteRule (^|/)(\.git|\.svn|\.hg|\.bzr|\.idea|\.vscode|node_modules|vendor|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|Gemfile(\.lock)?|requirements\.txt|Pipfile(\.lock)?|webpack\.config\.js|gulpfile\.js|gruntfile\.js|Dockerfile|docker-compose\.ya?ml|Makefile)(/|$) - [F,NC,L]

# Block source-map exposure (information leak from bundlers, if any).
RewriteRule \.(map|sql\.gz|tar|tar\.gz|tgz|7z|rar)$ - [F,NC,L]

# Common WP/CMS probe paths — return 410 (Gone) so Google de-indexes any
# that ever made it into the index. Anchored to URI prefixes so subpaths
# (e.g. /wp-content/plugins/foo.php) are caught too.
RewriteRule ^(wp-admin|wp-includes|wp-json|wp-content/(plugins|themes|mu-plugins|uploads/[0-9]+/[0-9]+))(/|$) - [G,NC,L]
RewriteRule ^(wp-login\.php|wp-config\.php|wp-cron\.php|wp-mail\.php|wp-trackback\.php|wp-signup\.php|wp-links-opml\.php|wp-comments-post\.php|wlwmanifest\.xml|xmlrpc\.php2?)$ - [G,NC,L]

# Block other CMS probe surfaces (Joomla / Drupal / Magento fingerprints).
RewriteRule ^(administrator|admin/login|user/login|configuration\.php|sites/default/files|magmi|joomla|drupal|typo3|phpmyadmin|pma|adminer|setup-config)(/|$) - [F,NC,L]

# Block PHP / CGI / scripting execution. Site is fully static; any .php
# that lands on disk must be treated as compromise, not feature.
RewriteRule \.(php[0-9s]?|phtml|phar|cgi|pl|py|asp|aspx|jsp|jspx|war)$ - [F,NC,L]

# Author-enumeration probe (?author=1 returns WP username on stock WP).
RewriteCond %{QUERY_STRING} (^|&)author=\d [NC]
RewriteRule .* - [F,L]

# Suspicious query strings — SQLi / XSS / RFI / spam payloads. Tight regex
# so real site queries (none today, but defensive for future tools) survive.
RewriteCond %{QUERY_STRING} (<|%3c)\s*script [NC,OR]
RewriteCond %{QUERY_STRING} (union[\s+/*]+select|insert\s+into|drop\s+table|cast\s*\(|concat\s*\() [NC,OR]
RewriteCond %{QUERY_STRING} (base64_(en|de)code|eval\s*\(|gzinflate\s*\(|system\s*\(|passthru\s*\() [NC,OR]
RewriteCond %{QUERY_STRING} (\.\./|%2e%2e%2f|%2e%2e/|\.\.%2f) [NC,OR]
RewriteCond %{QUERY_STRING} (file=https?://|=http://[^/]+/[^/]+\.(txt|php)) [NC]
RewriteRule .* - [F,L]

# Block server-status / server-info / cgi-bin probes.
RewriteRule ^(server-status|server-info|cgi-bin|fcgi-bin)(/|$) - [F,NC,L]

