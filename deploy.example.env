# ──────────────────────────────────────────────────────────────────────────
# deploy.example.env — template for local Hostinger uploads.
#
# 1. Copy this file to .deploy.env  (which is gitignored — NEVER commit it):
#        cp deploy.example.env .deploy.env
# 2. Fill in the values below.
# 3. Build + upload:
#        bash tools/local-deploy.sh            # build only
#        bash tools/upload-hostinger.sh --dry-run
#        bash tools/upload-hostinger.sh        # real upload (asks to confirm)
#
# These mirror the GitHub Actions secrets (HOSTINGER_FTP_SERVER / _USERNAME /
# _PASSWORD) used by .github/workflows/deploy.yml.
# ──────────────────────────────────────────────────────────────────────────

# ftps (matches CI, port 21) or sftp (Hostinger SSH, usually port 65002).
DEPLOY_PROTOCOL=ftps

# Raw server IP is most reliable on Hostinger shared hosting — the ftp.<domain>
# label often does not resolve. Get the current IP with:  dig +short ambisecure.ambimat.com
DEPLOY_HOST=

# Leave blank to default: 21 for ftps, 65002 for sftp.
DEPLOY_PORT=

# Full FTP/SSH username (e.g. u1234567.githubdeploy).
DEPLOY_USER=

# Password for the FTP/SSH account. Required for ftps, and for sftp unless
# DEPLOY_SSH_KEY is set. Keep this file out of git.
DEPLOY_PASS=

# Optional: path to an SSH private key for sftp key-based auth (then DEPLOY_PASS
# is not needed). Leave blank for password auth.
DEPLOY_SSH_KEY=

# Remote target dir. The Hostinger deploy account is scoped to public_html,
# so "./" lands files directly in the web root (matches CI server-dir).
DEPLOY_REMOTE_DIR=./

# What to upload. Defaults to the built tree; normally leave as-is.
DEPLOY_LOCAL_DIR=dist/ambisecure-hostinger

# Hostinger's shared FTPS cert is *.hstgr.io and won't match the host/IP.
# false = skip the hostname-to-cert check (channel still encrypted) — this is
# the same as security:loose in the CI workflow. Set true only with a matching cert.
DEPLOY_FTPS_VERIFY=false

# DANGER: when true, AND you pass --delete, remote files not present locally are
# DELETED (true mirror). Default false = additive/overwrite only. Leave false
# unless you fully understand the consequences.
DEPLOY_ALLOW_DELETE=false
