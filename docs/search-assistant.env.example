# AmbiSecure search / discovery-assistant configuration (example).
#
# This file documents the build-time flag that governs the discovery
# assistant. The site is statically hosted, so the runtime source of truth
# is assets/js/assistant-config.js; this .env mirrors the intended value for
# any future build pipeline that wants to template the config.
#
# AI is DISABLED BY DEFAULT and MUST stay disabled in production.

# Master switch for a FUTURE AI/RAG retrieval mode. Keep false.
# false = the shipped deterministic, non-AI search/intent assistant only.
ENABLE_AI_ASSISTANT=false
