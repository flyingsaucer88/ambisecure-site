{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "http://localhost/index.html",
        "http://localhost/blog/index.html",
        "http://localhost/products/onepass-platform/index.html",
        "http://localhost/case-studies/passwordless-workforce/index.html",
        "http://localhost/brochures/onepass/index.html",
        "http://localhost/resources/tools/apdu-parser/index.html",
        "http://localhost/search/index.html",
        "http://localhost/privacy/index.html"
      ],
      "settings": {
        "preset": "desktop",
        "throttling": { "cpuSlowdownMultiplier": 1 }
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance":   ["error", { "minScore": 0.90 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices":["error", { "minScore": 0.95 }],
        "categories:seo":           ["error", { "minScore": 0.95 }],

        "uses-text-compression":    "off",
        "csp-xss":                  "off",
        "errors-in-console":        "off"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./.lighthouseci"
    }
  }
}
